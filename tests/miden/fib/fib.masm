# Generates Fibonacci sequence from advice stack inputs
# Input: advice_stack contains [fib_a, fib_b, iterations] (usually [0, 1, n])
# Output: Returns the nth Fibonacci number
use.std::sys

begin
    adv_push.1
    adv_push.1
    adv_push.1
    dup neq.0
    
    while.true
        movdn.2
        dup.1
        add
        swap
        movup.2
        sub.1
        dup neq.0
    end
    
    drop
    drop
    exec.sys::truncate_stack
end
